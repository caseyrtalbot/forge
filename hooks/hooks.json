{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session-init.cjs\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/phase-gate.cjs\"",
            "timeout": 15
          }
        ],
        "description": "Prevents code edits when the current workflow phase requires design or planning first"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/commit-guardian.cjs\"",
            "timeout": 15
          }
        ],
        "description": "Validates verification has passed before allowing git commits"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/evidence-collector.cjs\"",
            "timeout": 15
          }
        ],
        "description": "Captures test results and build outputs as verification evidence"
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session-capture.cjs\"",
            "timeout": 15
          }
        ],
        "description": "Saves workflow state for cross-session continuity"
      }
    ]
  }
}
